<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- M4 バックグラウンド継続: 背面かつPrefetch稼働中のFGS昇格と進捗通知に必要 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 電池最適化除外要求ダイアログ(Settings.ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS)に必要。
         これが無いとlaunch時にSecurityExceptionが投げられ、runCatchingで握り潰されて何も起きない。 -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".KomrdApplication"
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.KomRD">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- WorkManager のFGS昇格(API31-33経路)。dataSync型宣言はAPI34+で必須・minSdk31でも安全のため宣言。 -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- API34+経路のUIDT(JobScheduler userInitiated)によるFGSホールド。 -->
        <service
            android:name="dev.komrd.core.prefetch.background.PrefetchJobService"
            android:foregroundServiceType="dataSync"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="false" />

        <!-- M4: WorkManagerの自動初期化を抑制し、KomrdApplication(Configuration.Provider)のHiltWorkerFactoryを使う。 -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
</manifest>