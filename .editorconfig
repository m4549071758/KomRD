root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_style = space
indent_size = 4
ktlint_function_naming_ignore_when_annotated_with = Composable

# LumoUI 生成コードは camelCase の定数プロパティを持つため property-naming ルールを無効化（ADR-0007）。
# 手組ラッパは本ルールに準拠済みで他の ktlint ルールは維持される。
[core/designsystem/src/main/kotlin/dev/komrd/core/designsystem/**]
ktlint_standard_property-naming = disabled
